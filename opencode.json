{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-forge",
    "opencode-subagent-statusline"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "env": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      }
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "D:/WorkShop/OpenCode", "C:/Users/ahmed/Desktop", "C:/Users/ahmed/AppData/Local/Temp/opencode"],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory", "C:/Users/ahmed/.opencode-memory.json"],
      "enabled": true
    }
  }
}
