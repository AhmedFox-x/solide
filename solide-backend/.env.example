DATABASE_URL="file:./dev.db"
JWT_SECRET="change-this-to-a-random-secret"
PORT=4000
FRONTEND_URL="http://localhost:5173"
UPLOAD_DIR="./uploads"

# Owner contact (used for notifications)
# OWNER_WHATSAPP="201060512080"   # default from site data
# OWNER_EMAIL="owner@example.com"

# WhatsApp via Twilio (optional — skip if not configured)
# TWILIO_ACCOUNT_SID="your_twilio_account_sid"
# TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Email via SMTP (optional — skip if not configured)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="Solide Orders <your@gmail.com>"
